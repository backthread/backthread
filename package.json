{
  "name": "backthread-oss",
  "version": "0.1.0",
  "private": true,
  "description": "Backthread open-source monorepo — the `backthread` CLI, the `@backthread/redact` fence, and the `@backthread/extractor` structural extractor.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backthread/backthread.git"
  },
  "type": "module",
  "workspaces": [
    "cli",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "bump": "node scripts/bump-version.mjs"
  }
}
